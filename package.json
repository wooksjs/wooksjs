{
  "name": "wooksjs",
  "version": "0.7.4",
  "private": true,
  "description": "wooksjs - web app framework with hooks",
  "keywords": [
    "application",
    "framework",
    "http",
    "rest",
    "restful",
    "server",
    "web",
    "wooks",
    "wooksjs"
  ],
  "homepage": "https://github.com/wooksjs/wooksjs#readme",
  "bugs": {
    "url": "https://github.com/wooksjs/wooksjs/issues"
  },
  "license": "MIT",
  "author": "Artem Maltsev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wooksjs/wooksjs.git"
  },
  "type": "module",
  "main": "index.js",
  "scripts": {
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "docs": "vitepress dev docs --host \"0.0.0.0\"",
    "docs-build": "vitepress build docs",
    "docs-serve": "vitepress serve docs --host \"0.0.0.0\"",
    "build": "node ./scripts/build.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "version": "pnpm changelog && git add CHANGELOG.md && git commit -m 'chore: update changelog'",
    "release": "pnpm build && pnpm lint && pnpm test && node ./scripts/versions && pnpm publish -r --access public",
    "sync": "node ./scripts/versions",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@prostojs/dye": "^0.4.9",
    "@prostojs/logger": "^0.4.3",
    "@types/node": "^22.19.11",
    "chart.js": "^4.5.1",
    "conventional-changelog-cli": "^5.0.0",
    "husky": "^9.1.7",
    "inquirer": "^12.11.1",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "rolldown": "1.0.0-beta.19",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.3.0",
    "typescript": "^5.9.3",
    "unplugin-isolated-decl": "^0.10.7",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4",
    "vue-chartjs": "^5.3.3",
    "zx": "^8.8.5"
  },
  "pnpm": {
    "overrides": {
      "@conventional-changelog/git-client": "^2.0.0",
      "esbuild": ">=0.25.0"
    }
  }
}
