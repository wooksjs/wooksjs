    "__DYE_GRAY01__": "readonly",
    "__DYE_BG_GRAY01__": "readonly",
    "__DYE_GRAY02__": "readonly",
    "__DYE_BG_GRAY02__": "readonly",
    "__DYE_GRAY03__": "readonly",
    "__DYE_BG_GRAY03__": "readonly",
    "__DYE_GRAY04__": "readonly",
    "__DYE_BG_GRAY04__": "readonly",
    "__DYE_GRAY05__": "readonly",
    "__DYE_BG_GRAY05__": "readonly",
    "__DYE_GRAY06__": "readonly",
    "__DYE_BG_GRAY06__": "readonly",
    "__DYE_GRAY07__": "readonly",
