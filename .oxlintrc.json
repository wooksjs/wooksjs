    "__DYE_BG_GRAY08__": "readonly",
    "__DYE_GRAY09__": "readonly",
    "__DYE_BG_GRAY09__": "readonly",
    "__DYE_GRAY10__": "readonly",
    "__DYE_BG_GRAY10__": "readonly",
    "__DYE_GRAY11__": "readonly",
    "__DYE_BG_GRAY11__": "readonly",
    "__DYE_GRAY12__": "readonly",
    "__DYE_BG_GRAY12__": "readonly",
    "__DYE_GRAY13__": "readonly",
    "__DYE_BG_GRAY13__": "readonly",
    "__DYE_GRAY14__": "readonly",
    "__DYE_BG_GRAY14__": "readonly",
    "__DYE_GRAY15__": "readonly",
    "__DYE_BG_GRAY15__": "readonly",
    "__DYE_GRAY16__": "readonly",
    "__DYE_BG_GRAY16__": "readonly",
    "__DYE_GRAY17__": "readonly",
