    "__DYE_CROSSED__": "readonly",
    "__DYE_CROSSED_OFF__": "readonly",
    "__DYE_BLACK__": "readonly",
    "__DYE_BG_BLACK__": "readonly",
    "__DYE_BLACK_BRIGHT__": "readonly",
    "__DYE_BG_BLACK_BRIGHT__": "readonly",
    "__DYE_RED__": "readonly",
    "__DYE_BG_RED__": "readonly",
    "__DYE_RED_BRIGHT__": "readonly",
    "__DYE_BG_RED_BRIGHT__": "readonly",
    "__DYE_GREEN__": "readonly",
    "__DYE_BG_GREEN__": "readonly",
    "__DYE_GREEN_BRIGHT__": "readonly",
    "__DYE_BG_GREEN_BRIGHT__": "readonly",
    "__DYE_YELLOW__": "readonly",
    "__DYE_BG_YELLOW__": "readonly",
    "__DYE_YELLOW_BRIGHT__": "readonly",
    "__DYE_BG_YELLOW_BRIGHT__": "readonly",
    "__DYE_BLUE__": "readonly",
    "__DYE_BG_BLUE__": "readonly",
    "__DYE_BLUE_BRIGHT__": "readonly",
    "__DYE_BG_BLUE_BRIGHT__": "readonly",
    "__DYE_MAGENTA__": "readonly",
    "__DYE_BG_MAGENTA__": "readonly",
    "__DYE_MAGENTA_BRIGHT__": "readonly",
