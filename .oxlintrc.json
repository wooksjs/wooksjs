{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "typescript", "unicorn", "promise"],
  "env": {
    "es2021": true,
    "node": true,
    "browser": false
  },
  "globals": {
    "Response": "readonly",
    "setTimeout": "readonly",
    "clearTimeout": "readonly",
    "fetch": "readonly",
    "process": "readonly",
    "console": "readonly",
    "Buffer": "readonly",
    "__VERSION__": "readonly",
    "__DYE_RESET__": "readonly",
    "__DYE_COLOR_OFF__": "readonly",
    "__DYE_BG_OFF__": "readonly",
    "__DYE_BOLD__": "readonly",
    "__DYE_BOLD_OFF__": "readonly",
    "__DYE_DIM__": "readonly",
